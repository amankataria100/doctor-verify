# ─────────────────────────────────────────────────────────
# Doctor Verification — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────────

# Option 1: Surepass NMC API
# Sign up at: https://surepass.io/nmc-verification-api/
# Free trial usually available
SUREPASS_TOKEN=your_surepass_bearer_token_here

# Option 2: IDfy via RapidAPI
# Sign up at: https://rapidapi.com/idfy-idfy-default/api/mci-nmc-doctor-verification
# Freemium plan available
RAPIDAPI_KEY=your_rapidapi_key_here

# Leave both blank = falls back to NMC portal scraper (free, no key needed)
